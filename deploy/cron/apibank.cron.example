# APIBank production cron examples. Use the target server IP in --resolve while DNS is moving.
* * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/acb >/dev/null 2>&1
*/3 * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/vcb >/dev/null 2>&1
*/3 * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/vpbank >/dev/null 2>&1
*/3 * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/techcombank >/dev/null 2>&1
*/3 * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/mbbank >/dev/null 2>&1
*/2 * * * * curl -sS --resolve apibank.com.vn:443:150.95.113.11 --max-time 120 https://apibank.com.vn/cron/techcombank-refresh >/dev/null 2>&1
