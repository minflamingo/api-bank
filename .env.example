APP_NAME="API Bank"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://apibank.com.vn

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apibank
